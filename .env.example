# =====================================================================
# fx-royal-road-monitor - Environment variables
# Copy to .env (gitignored) and fill in actual values.
# =====================================================================

# --- AI providers (both used for dual review; either can be disabled) ---
# Defaults are deliberately safe: providers disabled, mock on, dry-run on.
# Flip OPENAI_ENABLED / ANTHROPIC_ENABLED to true (and supply keys) when
# you actually want to call the real APIs. install with: pip install -e .[api]
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_ENABLED=false

# Use mock reviewer instead of real APIs (dev / CI dry-run)
AI_USE_MOCK=true

# --- Knowledge pack ---
KNOWLEDGE_PACK_PATH=docs/ROYAL_ROAD_KNOWLEDGE_PACK_v1.md

# --- Symbols & timeframes ---
SYMBOLS=USDJPY,EURUSD
TIMEFRAMES=M5,H1,H4

# --- Notification channels (set NOTIFY_BACKEND=console for local dev) ---
NOTIFY_BACKEND=console
DISCORD_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=

# --- Rendering ---
FX_MONITOR_RENDER_CARD=false
FX_MONITOR_CARD_PATH=out/notification_card.png

# CJK font for the notification card. Leave both blank to use whatever
# matplotlib finds; install fonts-noto-cjk on the host to get good output.
# Never commit font files to this repo.
FX_MONITOR_FONT_FAMILY=
FX_MONITOR_CJK_FONT_PATH=

# --- Notification attachments ---
# When true (and a card was rendered), Discord/LINE will upload the PNG.
FX_MONITOR_ATTACH_CARD=true

# --- Runtime ---
DRY_RUN=true
LOG_LEVEL=INFO

# --- Optional: replay a captured royal-road payload (fixture mode) ---
# FX_MONITOR_FIXTURE_PATH=tests/fixtures/royal_road_ready_sell_payload.json

# --- Market data feed (read-only; no broker, no live, no paper) ---
# Used only when FX_MONITOR_FIXTURE_PATH is unset.
#   fixture | csv | yahoo
FX_MONITOR_FEED=fixture
FX_MONITOR_SYMBOL=EURUSD=X
FX_MONITOR_TIMEFRAME=M5
FX_MONITOR_MAX_CANDLES=300
FX_MONITOR_CSV_PATH=

# --- Rate limiting (avoid notification spam) ---
NOTIFY_COOLDOWN_SECONDS=900

# --- Explicitly NOT used in this repo (broker/live trading) ---
# OANDA_API_KEY=  -> belongs to youiti0925/test, not here
