# =====================================================================
# fx-royal-road-monitor v2 - Environment variables
# Copy to .env (gitignored) and fill in actual values.
#
# This is an OBSERVATION-ONLY system. No broker, no live trading, no
# paper trading, no notification dispatch. The AI judgement runs on the
# Claude Code subscription path — there is no API key requirement here.
# =====================================================================

# --- Path overrides ---
# By default the tools use the repository root as the data root. Set
# this to relocate data/ to another directory (useful for tests or
# multi-machine sync).
# FX_MONITOR_ROOT=

# --- Symbols & timeframes (used by build_corpus / check tools) ---
SYMBOLS=EURUSD=X
TIMEFRAMES=M5

# --- Logging ---
LOG_LEVEL=INFO

# --- Explicitly NOT used in this repo ---
# OANDA_API_KEY        -> live trading; never wire it up here.
# OPENAI_API_KEY       -> $0 design uses Claude Code subscription only.
# ANTHROPIC_API_KEY    -> $0 design uses Claude Code subscription only.
# DISCORD_WEBHOOK_URL  -> notification dispatch is permanently disabled.
# LINE_NOTIFY_TOKEN    -> notification dispatch is permanently disabled.
